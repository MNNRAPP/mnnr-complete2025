# Production Environment Variables
# Copy this file to .env.production and fill in your production values
#
# IMPORTANT: .env.production is gitignored — never commit real secrets!

# ==============================================
# CRITICAL: Server-side Only (NEVER use NEXT_PUBLIC_ prefix)
# ==============================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# CSRF Secret (generate with: openssl rand -hex 32)
CSRF_SECRET=your_production_csrf_secret_here

# Audit Trail Secret (generate with: openssl rand -hex 32)
AUDIT_TRAIL_SECRET=your_production_audit_secret_here

# Stripe Secret Key
STRIPE_SECRET_KEY=sk_live_your_production_stripe_key_here

# Stripe Webhook Secret (from Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret_here

# Resend API Key (for newsletter emails)
RESEND_API_KEY=re_your_production_resend_key_here

# Database Encryption Key (generate with: openssl rand -hex 32)
DB_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# ==============================================
# Client-side Safe (Can use NEXT_PUBLIC_ prefix)
# ==============================================

# Your production site URL
NEXT_PUBLIC_SITE_URL=https://mnnr.app

# Stripe Publishable Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_stripe_key_here

# ==============================================
# Optional Configuration
# ==============================================

# Trial period in days (default: 0)
TRIAL_PERIOD_DAYS=0

# Redis for distributed rate limiting (Upstash recommended)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Sentry for error monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-org-name
SENTRY_PROJECT=your-project-name

# Logging configuration
LOG_LEVEL=info
ENABLE_LOG_AGGREGATION=true

# ==============================================
# Security Checklist Before Deployment
# ==============================================
#
# [ ] Verify DATABASE_URL points to production Neon database
# [ ] Verify STRIPE_SECRET_KEY has NO NEXT_PUBLIC_ prefix
# [ ] Verify STRIPE_WEBHOOK_SECRET is configured
# [ ] Update NEXT_PUBLIC_SITE_URL to your production domain
# [ ] Test webhook endpoint with Stripe CLI
# [ ] Review CSP headers in next.config.js
# [ ] Set up error monitoring (Sentry)
# [ ] Configure Redis for rate limiting
# [ ] Run npm audit and fix vulnerabilities
# [ ] Test all critical user flows
