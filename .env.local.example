# MNNR Local Development Environment
# Copy this file to .env.local and fill in your values

# Database (Neon PostgreSQL) — REQUIRED
DATABASE_URL="postgresql://user:password@your-host.neon.tech/neondb?sslmode=require"

# CSRF Secret — REQUIRED
# Generate with: openssl rand -hex 32
CSRF_SECRET="your_csrf_secret_here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (Email / Newsletter) — Optional
RESEND_API_KEY=""

# Redis (Upstash) — Optional, in-memory fallback used if not set
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry Error Tracking — Optional
SENTRY_DSN=""

# Maintenance Mode
MAINTENANCE_MODE="false"
