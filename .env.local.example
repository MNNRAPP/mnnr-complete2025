# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Database (Neon PostgreSQL — pooled / PgBouncer connection string)
# Used by lib/db.ts (Prisma client) at runtime + prisma/schema.prisma datasource.
NEON_DATABASE_URL="postgresql://..."
# Direct (non-pooled) connection — used by Prisma Migrate.
NEON_DATABASE_URL_DIRECT="postgresql://..."

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Redis (Upstash) - Optional
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry Error Tracking - Optional
# Get these from https://sentry.io/settings/mnnrapp/projects/mnnr-api/keys/
# - NEXT_PUBLIC_SENTRY_DSN is the same DSN exposed to the browser SDK.
# - SENTRY_DSN is used by the server + edge SDKs.
# - SENTRY_AUTH_TOKEN is only needed at build time for sourcemap upload.
#   Generate at https://sentry.io/settings/account/api/auth-tokens/ with
#   scopes: org:read, project:read, project:write, project:releases.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="mnnrapp"
SENTRY_PROJECT="mnnr-api"

# Maintenance Mode
MAINTENANCE_MODE="false"
