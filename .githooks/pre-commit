#!/bin/bash
# Pre-commit hook: Detect hardcoded secrets before they reach the repo
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
NC='\033[0m' # No Color

# Patterns to detect
PATTERNS=(
  'npg_[A-Za-z0-9]+'           # Neon DB passwords
  'whsec_[A-Za-z0-9]+'         # Stripe webhook secrets
  'sk_live_[A-Za-z0-9]+'       # Stripe live secret keys
  'sk_test_[A-Za-z0-9]+'       # Stripe test secret keys
  'acct_[A-Za-z0-9]+'          # Stripe account IDs
  'postgresql://[^@]+@[^/]+'   # Database connection strings with credentials
  'neondb_owner:[A-Za-z0-9]+'  # Neon DB credentials
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|md|env|yaml|yml)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND_SECRETS=0

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -lEn "$pattern" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}[SECRET DETECTED]${NC} Pattern '$pattern' found in:"
    echo "$MATCHES" | while read -r file; do
      echo "  - $file"
      grep -En "$pattern" "$file" | head -3
    done
    FOUND_SECRETS=1
  fi
done

if [ $FOUND_SECRETS -eq 1 ]; then
  echo ""
  echo -e "${RED}COMMIT BLOCKED: Hardcoded secrets detected.${NC}"
  echo "Move credentials to environment variables and use process.env.*"
  echo "To bypass (NOT recommended): git commit --no-verify"
  exit 1
fi

exit 0
