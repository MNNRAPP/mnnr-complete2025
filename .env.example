# ========================================
# MNNR - Environment Variables
# ========================================

# -----------------
# Database (Neon PostgreSQL) — REQUIRED
# -----------------
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# -----------------
# CSRF Protection — REQUIRED
# Generate with: openssl rand -hex 32
# -----------------
CSRF_SECRET=your_csrf_secret_here

# -----------------
# Audit Trail (Optional)
# Generate with: openssl rand -hex 32
# -----------------
AUDIT_TRAIL_SECRET=your_audit_trail_secret_here

# -----------------
# Site Configuration
# -----------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------
# Stripe Configuration — REQUIRED for billing
# Get from dashboard.stripe.com
# -----------------
# SERVER ONLY — never prefix with NEXT_PUBLIC_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# PUBLIC — safe for client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# -----------------
# Resend (Email / Newsletter) — Optional
# Get from resend.com
# -----------------
RESEND_API_KEY=re_your_resend_api_key

# -----------------
# Redis / Upstash (Production Rate Limiting) — Optional
# In-memory rate limiting is used when Redis is not configured
# -----------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# -----------------
# Error Monitoring (Sentry) — Optional
# -----------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# -----------------
# Database Encryption — Optional
# Generate with: openssl rand -hex 32
# Required for encrypting sensitive database fields
# -----------------
DB_ENCRYPTION_KEY=your_64_hex_char_encryption_key

# -----------------
# Logging
# -----------------
LOG_LEVEL=info
ENABLE_LOG_AGGREGATION=false
